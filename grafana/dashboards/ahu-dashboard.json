{
  "dashboard": {
    "title": "HVAC Monitoring Dashboard (AHU-01)",
    "tags": ["hvac", "ahu", "facility"],
    "timezone": "browser",
    "refresh": "10s",
    "panels": [
      {
        "id": 1,
        "title": "AHU-01 System Overview",
        "type": "canvas",
        "gridPos": {"h": 16, "w": 18, "x": 0, "y": 0},
        "options": {
          "inlineEditing": false,
          "panZoom": false,
          "elements": [
            {
              "id": "oa-box",
              "type": "rectangle",
              "config": {
                "align": "center",
                "color": {"fixed": "#1a1a2e"},
                "text": {"fixed": "OA 외기"}
              },
              "placement": {"x": 20, "y": 80, "w": 80, "h": 60}
            },
            {
              "id": "damper-box",
              "type": "rectangle",
              "config": {
                "align": "center",
                "color": {"fixed": "#16213e"},
                "text": {"fixed": "DAMPER"}
              },
              "placement": {"x": 140, "y": 80, "w": 80, "h": 60}
            },
            {
              "id": "filter-box",
              "type": "rectangle",
              "config": {
                "align": "center",
                "color": {"fixed": "#16213e"},
                "text": {"fixed": "FILTER"}
              },
              "placement": {"x": 260, "y": 80, "w": 80, "h": 60}
            },
            {
              "id": "coil-box",
              "type": "rectangle",
              "config": {
                "align": "center",
                "color": {"fixed": "#16213e"},
                "text": {"fixed": "COOLING COIL"}
              },
              "placement": {"x": 380, "y": 80, "w": 80, "h": 60}
            },
            {
              "id": "fan-box",
              "type": "rectangle",
              "config": {
                "align": "center",
                "color": {"fixed": "#16213e"},
                "text": {"fixed": "SUPPLY FAN"}
              },
              "placement": {"x": 500, "y": 80, "w": 80, "h": 60}
            },
            {
              "id": "room-box",
              "type": "rectangle",
              "config": {
                "align": "center",
                "color": {"fixed": "#0f3460"},
                "text": {"fixed": "CLEAN ROOM"}
              },
              "placement": {"x": 630, "y": 60, "w": 100, "h": 100}
            }
          ]
        },
        "datasource": {"type": "influxdb", "uid": "influxdb"}
      },
      {
        "id": 2,
        "title": "OA Temp",
        "type": "stat",
        "gridPos": {"h": 4, "w": 3, "x": 18, "y": 0},
        "fieldConfig": {
          "defaults": {
            "unit": "celsius",
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 30},
                {"color": "red", "value": 35}
              ]
            }
          }
        },
        "targets": [{
          "query": "from(bucket: \"utility_data\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"hvac_ahu\") |> filter(fn: (r) => r._field == \"oa_temp\") |> last()",
          "refId": "A"
        }],
        "datasource": {"type": "influxdb", "uid": "influxdb"}
      },
      {
        "id": 3,
        "title": "Room Temp",
        "type": "stat",
        "gridPos": {"h": 4, "w": 3, "x": 21, "y": 0},
        "fieldConfig": {
          "defaults": {
            "unit": "celsius",
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 24},
                {"color": "red", "value": 26}
              ]
            }
          }
        },
        "targets": [{
          "query": "from(bucket: \"utility_data\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"hvac_ahu\") |> filter(fn: (r) => r._field == \"room_temp\") |> last()",
          "refId": "A"
        }],
        "datasource": {"type": "influxdb", "uid": "influxdb"}
      },
      {
        "id": 4,
        "title": "Temperature Trend",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "targets": [
          {
            "query": "from(bucket: \"utility_data\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"hvac_ahu\") |> filter(fn: (r) => r._field == \"oa_temp\" or r._field == \"sa_temp\" or r._field == \"ra_temp\" or r._field == \"room_temp\") |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)",
            "refId": "A"
          }
        ],
        "datasource": {"type": "influxdb", "uid": "influxdb"}
      },
      {
        "id": 5,
        "title": "Total Power (kW)",
        "type": "stat",
        "gridPos": {"h": 4, "w": 3, "x": 18, "y": 4},
        "fieldConfig": {
          "defaults": {
            "unit": "kwatt",
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 15},
                {"color": "red", "value": 20}
              ]
            }
          }
        },
        "targets": [{
          "query": "from(bucket: \"utility_data\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"hvac_ahu\") |> filter(fn: (r) => r._field == \"total_power\") |> last()",
          "refId": "A"
        }],
        "datasource": {"type": "influxdb", "uid": "influxdb"}
      }
    ],
    "schemaVersion": 38,
    "version": 0
  },
  "overwrite": true
}
